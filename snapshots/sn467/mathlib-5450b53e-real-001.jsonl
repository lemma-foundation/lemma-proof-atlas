{"theorem_name":"Finset.disjoint_filter","type_expr":"∀ {α : Type _} {s : Finset α} {p q : α → Prop} [DecidablePred p] [DecidablePred q], Disjoint (Finset.filter p s) (Finset.filter q s) ↔ ∀ x ∈ s, p x → ¬q x","imports":["Mathlib.Data.Finset.Basic"],"mathlib_rev":"5450b53e5ddc75d46418fabb605edbf36bd0beb6","source_path":"Mathlib/Data/Finset/Basic.lean","source_line":311,"source_license":"Apache-2.0","proof_sha256":"ab26df1887436bb35fb960078ee5082c670e8fbc660857c12dd773636e81d709","queue_depth":2,"topic":"Data","subtopic":"Finset","difficulty_score":6}
